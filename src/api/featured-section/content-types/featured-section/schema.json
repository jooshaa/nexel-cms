{
  "kind": "collectionType",
  "collectionName": "featured_sections",
  "info": {
    "singularName": "featured-section",
    "pluralName": "featured-sections",
    "displayName": "Featured Section",
    "description": "Homepage featured product sections"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "maxLength": 150,
      "required": true
    },
    "subtitle": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "maxLength": 300
    },
    "styleVariant": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "default": "grid",
      "enum": [
        "grid",
        "carousel",
        "hero-split",
        "list",
        "spotlight"
      ]
    },
    "products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product"
    },
    "active": {
      "type": "boolean",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "default": true
    },
    "order": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "default": 0,
      "min": 0
    },
    "backgroundStyle": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "default": "default",
      "enum": [
        "default",
        "dark",
        "accent",
        "muted"
      ]
    }
  }
}
