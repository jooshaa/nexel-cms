{
  "kind": "collectionType",
  "collectionName": "hero_slides",
  "info": {
    "singularName": "hero-slide",
    "pluralName": "hero-slides",
    "displayName": "Hero Slide",
    "description": "Homepage hero carousel slides"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 150
    },
    "subtitle": {
      "type": "string",
      "maxLength": 300
    },
    "buttonText": {
      "type": "string",
      "maxLength": 50
    },
    "buttonLink": {
      "type": "string",
      "maxLength": 255
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "mobileImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "order": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "textColor": {
      "type": "enumeration",
      "enum": ["light", "dark"],
      "default": "light"
    },
    "overlayOpacity": {
      "type": "decimal",
      "default": 0.3,
      "min": 0,
      "max": 1
    }
  }
}
