// ─────────────────────────────────────────────────────────────────────────────
// Nexel Frontend — Next.js environment variables
// Copy to: nexel-frontend/.env.local
// ─────────────────────────────────────────────────────────────────────────────

# CMS base URL (no trailing slash)
# Local dev:
NEXT_PUBLIC_CMS_URL=http://localhost:1337
# Production:
# NEXT_PUBLIC_CMS_URL=https://cms.nexel.com

# Read-only API token — create in Strapi admin → Settings → API Tokens
# IMPORTANT: Server-side only. Never expose this in client components.
CMS_API_TOKEN=your-strapi-read-only-api-token
